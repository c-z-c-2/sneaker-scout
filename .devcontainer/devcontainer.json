{
  "name": "Sneaker Scout Dev",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localWorkspaceFolder}/.claude,target=/home/chris/.claude,type=bind,consistency=cached"
  ],
  "remoteUser": "chris",
  "containerUser": "chris",
  "postCreateCommand": "bash /workspace/.devcontainer/post-create.sh",
  // Beads runs as a pure client against the Dolt server on the HOST
  // (launchd agent com.beads.dolt.sneaker-scout, host.docker.internal:3307).
  // Do NOT start a server in the container — just verify connectivity.
  "postStartCommand": "bd dolt show >/tmp/bd-conn.log 2>&1 || true",
  "forwardPorts": [8080],
  // Inject the Dolt password from a gitignored env file (never committed).
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/devcontainer.env"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteEnv": {
    "CHROME_BIN": "/usr/bin/chromium",
    "CHROMEDRIVER_PATH": "/usr/bin/chromedriver",
    "PYTHONPATH": "/workspace",
    "PATH": "${containerEnv:PATH}:/home/chris/.local/bin",
    "BEADS_DOLT_SERVER_MODE": "1",
    "BEADS_DOLT_SERVER_HOST": "host.docker.internal",
    "BEADS_DOLT_SERVER_PORT": "3307",
    "BEADS_DOLT_SERVER_DATABASE": "sneaker_scout",
    "BEADS_DOLT_AUTO_START": "0",
    "BEADS_DOLT_PASSWORD": "${containerEnv:BEADS_DOLT_PASSWORD}"
  }
}
